# CineForge — Environment Variables
# Copy this file to .env.local and fill in your values

# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# WalletConnect — required for mobile wallet connections
# Get a free project ID at https://cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=your-project-id

# ─── fal.ai — Video Generation (REQUIRED for real pipeline) ──────────────────
# Get your key at https://fal.ai/dashboard/keys
# ⚠️  This key must ONLY be set as a Supabase secret (server-side).
#     NEVER prefix it with VITE_ — it would be exposed to the browser.
#
# To deploy:
#   supabase secrets set FAL_KEY=your_fal_key_here
FAL_KEY=

# Optional: Legacy AI provider keys (replaced by fal.ai)
# VITE_REPLICATE_API_KEY=
# VITE_RUNWAY_API_KEY=
